# Domains
HUB_DOMAIN=hub.localhost
API_DOMAIN=api.hub.localhost
PAPERLESS_DOMAIN=paperless.localhost
PAYLOAD_DOMAIN=payload.localhost

# Core services
REDIS_PASSWORD=redis123
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_PREFIX=dreamlab
BLOB_READ_WRITE_TOKEN=
OLLAMA_URL=

# Email Lab (IMAP)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_TLS=true
IMAP_MAILBOX=INBOX

# Vault (plugin secrets)
# 32-byte base64 or 64 hex string
VAULT_MASTER_KEY=

# Payload (Neon by default)
PAYLOAD_SECRET=CHANGE_ME
DATABASE_URI=postgres://payload_user:payload_pass@ep-example.us-east-2.aws.neon.tech:5432/payload
NEON_SCHEMA_CORE=hub
NEON_SCHEMA_PAPERLESS=paperless
DATABASE_URI_CORE=
DATABASE_URI_PAPERLESS=
DATABASE_URI_PAYLOAD=
PAYLOAD_SCHEMA=payload

# Paperless (single source: .env -> generated services/paperless/docker-compose.env)
# Precedence: PAPERLESS_DATABASE_URL > DATABASE_URI_PAPERLESS > DATABASE_URI
PAPERLESS_DATABASE_URL=
PAPERLESS_SECRET_KEY=CHANGE_ME
PAPERLESS_URL=http://paperless.localhost
PAPERLESS_TIME_ZONE=UTC
PAPERLESS_OCR_LANGUAGE=eng
PAPERLESS_CONSUMER_POLLING=60
PAPERLESS_CONSUMER_POLLING_DELAY=5
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=admin
PAPERLESS_REDIS=redis://:redis123@redis:6379
# Optional overrides (derived from DATABASE_URI if empty)
PAPERLESS_DBHOST=
PAPERLESS_DBPORT=
PAPERLESS_DBNAME=
PAPERLESS_DBUSER=
PAPERLESS_DBPASS=
PAPERLESS_DBSSLMODE=
CLOUDFLARED_TOKEN=
HUB_CLOUDFLARED_TOKEN=
