# =============================================================================
# Supabase Environment Variables (Monorepo Documentation Template)
# =============================================================================
# This file documents ALL environment variables needed for the Supabase backend.
# In the monorepo, the active runtime env is always root .env.local via symlink.
#
# PRIORITY: Root .env.local is the active runtime source
# See: scripts/setup-env.sh for symlink management
# =============================================================================

# =============================================================================
# CORE SUPABASE CONFIGURATION
# =============================================================================

# Supabase Project Reference (from your Supabase dashboard)
SUPABASE_PROJECT_REF=your_project_ref_here

# Supabase URL - Local development URL
SUPABASE_URL=http://127.0.0.1:54321

# Supabase Anonymous Key (public, client-side)
# Get from: Supabase Dashboard > Project Settings > API > anon/public
SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (secret, server-side only!)
# Get from: Supabase Dashboard > Project Settings > API > service_role/secret
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Postgres connection string (for direct DB access)
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# =============================================================================
# AUTH CONFIGURATION (config.toml references)
# =============================================================================

# Primary site URL for OAuth redirects
SUPABASE_SITE_URL=http://127.0.0.1:5173

# Structured redirect inputs used by backends/supabase/scripts/render-safe-config.mjs
# Public domains live in backends/supabase/.env.public.
SUPABASE_REDIRECT_HUB_LOCAL_BASE_URLS=http://127.0.0.1:5173,http://localhost:5173
SUPABASE_REDIRECT_WEBSITE_LOCAL_BASE_URLS=http://127.0.0.1:4321,http://localhost:4321
SUPABASE_REDIRECT_EVIDENCE_LOCAL_BASE_URLS=http://127.0.0.1:5174,http://localhost:5174
SUPABASE_REDIRECT_UI_REACT_STORYBOOK_LOCAL_BASE_URLS=http://127.0.0.1:46001,http://localhost:46001
SUPABASE_REDIRECT_UI_ASTRO_STORYBOOK_LOCAL_BASE_URLS=
SUPABASE_REDIRECT_UI_VUE_STORYBOOK_LOCAL_BASE_URLS=
SUPABASE_REDIRECT_EXTRA_URLS=

# Platform admin emails (comma-separated)
PLATFORM_ADMIN_EMAILS=info@dreamlab.solutions

# =============================================================================
# OAUTH PROVIDERS (Enable in config.toml if needed)
# =============================================================================

# Google OAuth
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
SUPABASE_AUTH_EXTERNAL_GOOGLE_REDIRECT_URI=

# Discord OAuth
SUPABASE_AUTH_EXTERNAL_DISCORD_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_DISCORD_SECRET=
SUPABASE_AUTH_EXTERNAL_DISCORD_REDIRECT_URI=

# GitHub OAuth
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=
SUPABASE_AUTH_EXTERNAL_GITHUB_REDIRECT_URI=

# =============================================================================
# STRIPE INTEGRATION (Edge Functions)
# =============================================================================

# Stripe Secret Key (test or live)
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe Webhook Secret (for local webhook testing)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Publishable Key (public, starts with pk_test_ or pk_live_)
STRIPE_PUBISHABLE_SECRET=pk_test_xxx

# =============================================================================
# EDGE FUNCTIONS SECRETS
# =============================================================================

# OpenAI API Key (for AI features)
OPENAI_API_KEY=sk-xxx

# =============================================================================
# MONOREPO INTEGRATION
# =============================================================================

# NPM Token for private packages (if using @dreamlab-solutions packages)
NPM_TOKEN=your_npm_token_here

# Dev Runner Services (which services to start)
DEV_RUNNER_SERVICES=supabase-start,admin-ui,functions,ui-kit-playbook,webpage-engine-playbook,website-astro

# =============================================================================
# OPTIONAL / DEBUG
# =============================================================================

# Supabase CLI debug mode
# DEBUG=supabase:*

# =============================================================================
# NOTES
# =============================================================================
#
# 1. NEVER commit real values to git
# 2. In monorepo: edit root .env.local, then run 'pnpm setup:env' if the symlink is missing
# 3. Keep public domains in backends/supabase/.env.public
# 4. For production: Use 'supabase secrets set' for sensitive values
# 5. Edge Functions only get env vars explicitly set via secrets or --env-file
#
# Edge Function Secrets Setup:
#   supabase secrets set STRIPE_SECRET_KEY=sk_live_xxx
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_xxx
#   supabase secrets set PLATFORM_ADMIN_EMAILS=admin@example.com
#   supabase secrets list  # To verify
#
